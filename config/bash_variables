# NVM installation
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# global variables (append to PATH instead of overwriting)
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="/usr/local/git/bin:/usr/local/sbin:/usr/local/mysql/bin:$PATH"

## adding flatpak bin path
export PATH="$HOME/.local/share/flatpak/app/net.lutris.Lutris/x86_64/stable/2e580c2d27b44e1d2313ad7c73df33c2705aec8ef4b030e5a209278c0e0771e1/files/bin:$PATH"

# Server variables
export MACHINE_HOSTNAME=zero

# wine configurations
# export WINEARCH=win32
export WINEARCH=win64
export DISPLAY=:1

# Node configurations
# export NODE_OPTIONS=--max-old-space-size=4096

##  flatpack update for a fix
export XDG_DATA_DIRS="$XDG_DATA_DIRS:/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share"

## Updating the docker buildkit
export DOCKER_BUILDKIT=1

# VSCode shell integration
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path bash)" 2>/dev/null

# Local bin + Fly.io
[ -d "$HOME/.local/bin" ] && export PATH="$HOME/.local/bin:$PATH"
[ -d "$HOME/.fly/bin" ] && export PATH="$HOME/.fly/bin:$PATH"

# Angular CLI autocompletion
command -v ng &>/dev/null && source <(ng completion script) 2>/dev/null

# SDKMAN (must be at the end)
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

## for running node on linux using WSL
export PATH="$PATH:/mnt/c/Users/strubloid/AppData/Local/Programs/Microsoft VS Code/bin"

## configuring the ollama to be the antropic
export ANTHROPIC_BASE_URL="http://localhost:11434"

## any token for the localhost
export ANTHROPIC_AUTH_TOKEN="token"

## adding some context to ollama
export OLLAMA_NUM_CTX=8192

## addubg ollama host as 0.0.0.0 as an attemp to be able to use with docker machines
export OLLAMA_HOST=0.0.0.0